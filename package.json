{
  "name": "smart-finance-ai",
  "version": "1.0.0",
  "description": "Hệ thống quản lý tài chính thông minh tích hợp AI",
  "scripts": {
    "start": "concurrently -c \"cyan,magenta\" -n \"REACT,FASTAPI\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --reload --port 8000"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}